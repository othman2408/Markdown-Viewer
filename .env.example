PORT=8080
NODE_ENV=production

# PostgreSQL/Neon
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Single-owner login
ADMIN_EMAIL=owner@example.com
# Generate with: bun run hash-password -- --password=your-password
# Keep the bcrypt hash quoted because it contains `$`.
ADMIN_PASSWORD_HASH='$2a$12$replace-with-generated-bcrypt-hash'
SESSION_SECRET=replace-with-random-32-byte-secret

# HTTPS/reverse proxy deployment
PUBLIC_BASE_URL=https://markdown.example.com
COOKIE_SECURE=true
# Set to the exact number of trusted reverse proxies, for example 1 behind nginx/caddy.
TRUST_PROXY=1

# Cloudflare R2
R2_BUCKET=markdown-viewer
R2_ENDPOINT=https://account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-access-key
R2_SECRET_ACCESS_KEY=replace-with-secret-key
