{
  "name": "markdown-viewer-cloud",
  "version": "3.7.9-cloud.1",
  "private": true,
  "description": "Cloud-enabled Markdown Viewer with single-owner auth, Postgres persistence, and R2 assets.",
  "main": "server/index.ts",
  "scripts": {
    "start": "bun server/index.ts",
    "dev": "concurrently -k -n server,client \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "db:migrate": "bun server/migrate.ts",
    "hash-password": "bun server/hash-password.ts",
    "test": "bun test --timeout 30000 test/unit/unit.test.js test/contracts/dom-contract.test.js test/integration/integration.test.js",
    "test:browser": "node test/e2e/browser-smoke.js",
    "test:client": "vitest run --config vite.config.ts",
    "test:integration": "bun test --timeout 30000 test/integration/integration.test.js",
    "test:e2e": "bun run test:browser"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.705.0",
    "@highlightjs/cdn-assets": "^11.9.0",
    "bcryptjs": "^3.0.3",
    "bootstrap-icons": "^1.11.3",
    "connect-pg-simple": "^10.0.0",
    "dompurify": "^3.0.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "file-saver": "^2.0.5",
    "helmet": "^8.0.0",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.0",
    "marked": "^9.1.6",
    "multer": "^2.0.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "supertest": "^7.0.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
